{
  "name": "bolt95",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 8000",
    "build": "tsc -b && vite build",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc -b",
    "unit": "vitest run",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "npm run test:e2e:root && npm run test:e2e:subpath",
    "test:e2e:root": "BOLT95_BASE=/ playwright test",
    "test:e2e:subpath": "BOLT95_BASE=/BOLT95/ playwright test",
    "build:subpath": "tsc -b && vite build --mode subpath",
    "release:audit": "node scripts/audit-release.mjs",
    "release:check": "npm run format:check && npm run lint && npm run typecheck && npm run unit && npm run fetch:models && npm run build && npm run release:audit",
    "preview": "vite preview --host 127.0.0.1 --port 8000",
    "preview:subpath": "vite preview --host 127.0.0.1 --port 8000 --base /BOLT95/",
    "build:whisper": "./scripts/build-whisper-wasm.sh",
    "fetch:models": "node scripts/fetch-models.mjs",
    "fetch:fixture": "node scripts/fetch-whisper-fixture.mjs",
    "inspect:wasm": "node scripts/inspect-whisper-build.mjs"
  },
  "dependencies": {
    "dexie": "4.4.4",
    "mediabunny": "1.50.6",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "axe-core": "4.12.1",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.4",
    "typescript": "6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "8.1.3",
    "vitest": "4.1.10"
  }
}
